<h1>NZ Income Tax Calculator</h1>
<p>Enter an annual income in NZD to estimate tax using the 2025 bands.</p>

<%= form_with model: @income_input, url: calculator_path do |form| %>
  <p>
    <%= form.label :amount, "Annual income" %><br>
    <%= form.number_field :amount, step: "0.01", min: "0", placeholder: "100000" %>
  </p>

  <% @income_input.errors.full_messages_for(:amount).each do |message| %>
    <p class="error"><%= message %></p>
  <% end %>

  <p><%= form.submit "Calculate tax" %></p>
<% end %>

<% if @calculation %>
  <h2>Result</h2>
  <p>Income: <strong><%= number_to_currency(@income_input.income, unit: "$", precision: 2) %></strong></p>
  <p>Tax to pay: <strong><%= number_to_currency(@calculation.tax_owed, unit: "$", precision: 2) %></strong></p>
<% end %>
